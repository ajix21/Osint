APP_NAME="LeakOSINT Tool"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=leakosint_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── LeakOSINT API ───────────────────────────────
# URL endpoint API (jangan diubah kecuali ada perubahan dari provider)
LEAKOSINT_API_URL=https://leakosintapi.com/

# Token API global (digunakan jika user tidak punya token pribadi)
# Dapatkan token dari: https://leakosint.com
LEAKOSINT_API_TOKEN=

# ─── Brute-Force Protection ──────────────────────
# Jumlah maksimal percobaan gagal sebelum akun dikunci
AUTH_MAX_ATTEMPTS=5

# Durasi kunci dalam menit
AUTH_LOCKOUT_MINUTES=15
