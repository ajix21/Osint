APP_NAME="LeakOSINT Tool"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=leakosint_db
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── LeakOSINT API ──────────────────────────────────
LEAKOSINT_API_URL=https://leakosintapi.com/
LEAKOSINT_API_TOKEN=

# ─── Brute-Force Protection ────────────────
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
